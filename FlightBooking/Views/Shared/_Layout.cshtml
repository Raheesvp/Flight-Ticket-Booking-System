<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkyLogistics</title>
    
    <!-- Google Fonts for Aviation feel -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
    
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #F8FAFC;
            color: #1E293B;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Aviation-Grade Navbar */
        .aviation-navbar {
            background: linear-gradient(135deg, #0A192F 0%, #0B2B42 100%);
            border-bottom: 2px solid #F59E0B;
            padding: 1rem 0;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .navbar-brand-custom {
            font-family: 'Space Grotesk', monospace;
            font-size: 1.65rem;
            font-weight: 700;
            letter-spacing: 1px;
            background: linear-gradient(135deg, #FFFFFF, #94A3B8);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .navbar-brand-custom i {
            color: #F59E0B;
            background: none;
            -webkit-background-clip: unset;
            background-clip: unset;
            margin-right: 8px;
        }

        .navbar-brand-custom:hover {
            transform: translateY(-1px);
            text-shadow: 0 0 8px rgba(245, 158, 11, 0.3);
        }

        .nav-link-custom {
            color: #E2E8F0 !important;
            font-weight: 500;
            padding: 0.5rem 1.2rem !important;
            margin: 0 0.2rem;
            border-radius: 8px;
            transition: all 0.25s ease;
            font-size: 0.95rem;
            letter-spacing: 0.3px;
        }

        .nav-link-custom:hover {
            color: white !important;
            background: rgba(245, 158, 11, 0.2);
            transform: translateY(-2px);
        }

        .login-btn {
            background: rgba(245, 158, 11, 0.9);
            color: #0A192F !important;
            border-radius: 25px !important;
            padding: 0.5rem 1.5rem !important;
            font-weight: 600 !important;
            margin-left: 0.5rem;
            transition: all 0.3s;
        }

        .login-btn:hover {
            background: #F59E0B;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(245, 158, 11, 0.4);
            color: #0A192F !important;
        }

        /* Main Content Card Viewport */
        .main-viewport {
            flex: 1;
            background: white;
            border-radius: 24px;
            box-shadow: 0 10px 35px -10px rgba(0, 0, 0, 0.08);
            margin: 1.5rem auto;
            padding: 2rem;
            border: 1px solid rgba(0, 0, 0, 0.05);
            transition: all 0.2s ease;
            min-height: 65vh;
        }

        /* Aviation Grade Indicator */
        .viewport-badge {
            display: inline-block;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 1px;
            background: #F1F5F9;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            color: #475569;
            margin-bottom: 1.5rem;
            border-left: 3px solid #F59E0B;
        }

        /* Footer Styling - Airline Style */
        .aviation-footer {
            background: #0A192F;
            color: #CBD5E1;
            padding: 3rem 0 1.5rem;
            margin-top: auto;
            border-top: 1px solid #1E3A5F;
        }

        .footer-heading {
            font-family: 'Space Grotesk', monospace;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #F59E0B;
            margin-bottom: 1.2rem;
        }

        .footer-links {
            list-style: none;
            padding-left: 0;
        }

        .footer-links li {
            margin-bottom: 0.6rem;
        }

        .footer-links a {
            color: #94A3B8;
            text-decoration: none;
            font-size: 0.85rem;
            transition: all 0.2s;
        }

        .footer-links a:hover {
            color: #F59E0B;
            padding-left: 3px;
        }

        .footer-contact {
            font-size: 0.85rem;
            margin-bottom: 0.4rem;
        }

        .footer-contact i {
            width: 28px;
            color: #F59E0B;
        }

        .copyright {
            border-top: 1px solid #1E3A5F;
            padding-top: 1.8rem;
            margin-top: 2rem;
            font-size: 0.75rem;
            text-align: center;
            color: #64748B;
        }

        /* Responsive tweaks */
        @@media (max-width: 768px) {
            .main-viewport {
                padding: 1.25rem;
                margin: 1rem;
                border-radius: 20px;
            }
            .aviation-footer {
                padding: 2rem 0 1rem;
            }
            .navbar-brand-custom {
                font-size: 1.3rem;
            }
        }
    </style>
</head>
<body>

    <!-- SKYLOGISTICS NAVIGATION BAR - Aviation Grade -->
    <nav class="aviation-navbar">
        <div class="container">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <!-- Brand Logo -->
                <a class="navbar-brand-custom" href="/">
                    <i class="fas fa-plane-departure"></i> SkyLogistics
                </a>

                <!-- Desktop Navigation Toggle for mobile -->
                <button class="navbar-toggler d-lg-none btn btn-outline-light btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#aviationNavMenu" aria-expanded="false">
                    <i class="fas fa-bars"></i> Menu
                </button>

                <!-- Navigation Links -->
                <div class="collapse d-lg-flex" id="aviationNavMenu">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Flight" asp-action="Search">
                                <i class="fas fa-search me-1"></i> Search Flights
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Booking" asp-action="MyBookings">
                                <i class="fas fa-ticket-alt me-1"></i> My Bookings
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Account" asp-action="Profile">
                                <i class="fas fa-user-circle me-1"></i> Profile
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link login-btn" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-key me-1"></i> LOGIN
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <!-- MAIN DYNAMIC VIEWPORT - MVC Views injected here -->
    <div class="container">
        <div class="main-viewport">
            <!-- Small badge to emphasize aviation-grade structural integrity -->
            <div class="viewport-badge">
                <i class="fas fa-chart-line me-1"></i> AVIATION-GRADE VIEWPORT | SECURE TRANSACTION LAYER
            </div>
            
            <!-- Main content area from child views -->
            @RenderBody()
            
            <!-- Additional note: dynamic MVC view injection exactly here -->
            <div class="text-muted mt-4 small text-end opacity-50">
                <i class="fas fa-microchip"></i> flight core v2.4
            </div>
        </div>
    </div>

    <!-- FOOTER - Complete SkyLogistics Design -->
    <footer class="aviation-footer">
        <div class="container">
            <div class="row gy-4">
                <!-- Brand Column -->
                <div class="col-lg-4 col-md-6">
                    <div class="mb-3">
                        <i class="fas fa-rocket fs-4" style="color: #F59E0B;"></i>
                        <span class="fw-bold fs-5 text-white ms-2">SkyLogistics</span>
                    </div>
                    <p class="small text-secondary-emphasis" style="color: #9CA3AF !important;">
                        Empowering global travel with precision logistics and next-generation flight management.
                    </p>
                    <div class="mt-3">
                        <i class="fab fa-twitter me-2 text-secondary"></i>
                        <i class="fab fa-linkedin-in me-2 text-secondary"></i>
                        <i class="fab fa-instagram text-secondary"></i>
                    </div>
                </div>

                <!-- TRAVELERS Section -->
                <div class="col-lg-2 col-md-6">
                    <h5 class="footer-heading">TRAVELERS</h5>
                    <ul class="footer-links">
                        <li><a href="#"><i class="fas fa-chevron-right fa-xs me-1"></i> Manage Bookings</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right fa-xs me-1"></i> Flight Status</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right fa-xs me-1"></i> Check-in</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right fa-xs me-1"></i> Help Center</a></li>
                    </ul>
                </div>

                <!-- LEGAL Section -->
                <div class="col-lg-2 col-md-6">
                    <h5 class="footer-heading">LEGAL</h5>
                    <ul class="footer-links">
                        <li><a href="#">Terms of Service</a></li>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Accessibility</a></li>
                        <li><a href="#">Cookie Policy</a></li>
                    </ul>
                </div>

                <!-- CONTACT Section -->
                <div class="col-lg-4 col-md-6">
                    <h5 class="footer-heading">CONTACT</h5>
                    <div class="footer-contact">
                        <i class="fas fa-envelope"></i> support@skylogistics.aero
                    </div>
                    <div class="footer-contact">
                        <i class="fas fa-phone-alt"></i> +1 (800) SKY-FLGT
                    </div>
                    <div class="footer-contact mt-2">
                        <i class="fas fa-map-marker-alt"></i> 747 Aviation Blvd, Flight District
                    </div>
                </div>
            </div>
            
            <div class="copyright">
                © 2024 SkyLogistics Aviation. All rights reserved. | Precision engineered flight ecosystem
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Optional: additional scripts section for child views -->
    @await RenderSectionAsync("Scripts", required: false)
    
    <!-- Extra initialization for dropdowns/tooltips if needed -->
    <script>
        // Enable Bootstrap dropdown toggles anywhere if needed
        document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(btn => {
            // Native bootstrap handles this, just ensures dynamic content works.
        });
    </script>
</body>
</html>