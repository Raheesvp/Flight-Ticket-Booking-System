@{
    var ctrl   = ViewContext.RouteData
                    .Values["controller"]?.ToString();
    var action = ViewContext.RouteData
                    .Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport"
        content="width=device-width, initial-scale=1" />
  <title>@ViewData["Title"] — Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
        rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
        rel="stylesheet" />
  <link rel="stylesheet" href="~/css/admin.css"
        asp-append-version="true" />
</head>
<body class="admin-body">

<div class="admin-wrapper">

  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <div class="sidebar-brand">
      <i class="bi bi-airplane-fill me-2"></i>
      Admin Panel
    </div>

    <nav class="sidebar-nav">
      <a class="sidebar-link
         @(action=="Index" ? "active" : "")"
         asp-controller="Admin" asp-action="Index">
        <i class="bi bi-speedometer2"></i> Dashboard
      </a>
      <a class="sidebar-link
         @(action=="Flights" ? "active" : "")"
         asp-controller="Admin" asp-action="Flights">
        <i class="bi bi-airplane"></i> Flights
      </a>
      <a class="sidebar-link
         @(action=="Bookings" ? "active" : "")"
         asp-controller="Admin" asp-action="Bookings">
        <i class="bi bi-ticket-perforated"></i> Bookings
      </a>
      <a class="sidebar-link
         @(action=="Users" ? "active" : "")"
         asp-controller="Admin" asp-action="Users">
        <i class="bi bi-people"></i> Users
      </a>
      <a class="sidebar-link
         @(action=="Airlines" ? "active" : "")"
         asp-controller="Admin" asp-action="Airlines">
        <i class="bi bi-building"></i> Airlines
      </a>
    </nav>

    <div class="sidebar-footer">
      <a asp-controller="Home" asp-action="Index"
         class="sidebar-link">
        <i class="bi bi-house"></i> Back to site
      </a>
      <form asp-controller="Account"
            asp-action="Logout" method="post">
        <button type="submit" class="sidebar-link w-100">
          <i class="bi bi-box-arrow-left"></i> Logout
        </button>
      </form>
    </div>
  </aside>

  <!-- Main content -->
  <div class="admin-main">
    <header class="admin-topbar">
      <h5 class="mb-0">@ViewData["Title"]</h5>
      <span class="text-muted small">
        <i class="bi bi-person-circle me-1"></i>
        @User.Identity.Name
      </span>
    </header>
    <div class="admin-content">
      @RenderBody()
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>