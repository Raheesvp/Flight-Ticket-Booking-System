@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="container text-center my-5 py-5">
    <div class="spinner-border text-primary" role="status"></div>
    <h3 class="mt-4">Redirecting Securely to Payment Gateway Gateway...</h3>
    <p class="text-muted">Please do not close this browser window or press back buttons.</p>
    
    <button id="rzp-button1" class="btn btn-success btn-lg px-5 mt-3 d-none">Pay with Razorpay</button>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
    var options = {
        "key": "@ViewBag.RazorpayKeyId",
        "amount": "@ViewBag.AmountPaisa",
        "currency": "INR",
        "name": "Alhind Flight Booking",
        "description": "Secure Ticket Transaction Platform",
        "order_id": "@ViewBag.OrderId",
        "handler": function (response){
            fetch('/Booking/ProcessPayment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value },
                body: JSON.stringify({
                    RazorpayOrderId: response.razorpay_order_id,
                    RazorpayPaymentId: response.razorpay_payment_id,
                    RazorpaySignature: response.razorpay_signature,
                    FlightId: @ViewBag.FlightId
                })
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    window.location.href = '/Booking/Confirmation?id=' + data.bookingId + '&pnr=' + data.pnr;
                } else {
                    alert(data.message);
                }
            });
        },
        "theme": { "color": "#1a1a2e" }
    };
    var rzp1 = new Razorpay(options);
    window.onload = function() { rzp1.open(); };
</script>
@Html.AntiForgeryToken()