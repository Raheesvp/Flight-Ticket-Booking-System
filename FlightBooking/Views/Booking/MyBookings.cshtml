@* Views/Booking/MyBookings.cshtml *@
@model FlightBooking.Web.Models.ViewModels.BookingHistoryViewModel
@{
    ViewData["Title"] = "My Travel Dashboard";
}

<div class="container my-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="text-navy fw-bold"><i class="bi bi-backpack2-fill me-2"></i>My Bookings Dashboard</h2>
            <p class="text-secondary">Track, manage, and download documentation for your upcoming or historical flight itineraries.</p>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4" id="bookingTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active text-navy fw-bold" id="active-tab" data-bs-toggle="tab" data-bs-target="#active" type="button" role="tab">
                Upcoming Trips <span class="badge bg-orange ms-1">@Model.ActiveBooking.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link text-secondary" id="past-tab" data-bs-toggle="tab" data-bs-target="#past" type="button" role="tab">
                Completed Journeys <span class="badge bg-secondary ms-1">@Model.PastBooking.Count</span>
            </button>
        </li>
    </ul>

    <div class="tab-content" id="bookingTabsContent">

        <div class="tab-pane fade show active" id="active" role="tabpanel">
            @if (!Model.ActiveBooking.Any())
            {
                <div class="text-center p-5 border rounded bg-light">
                    <i class="bi bi-airplane text-muted display-4"></i>
                    <h5 class="mt-3 text-secondary">No upcoming journeys discovered.</h5>
                    <a asp-action="Index" asp-controller="Home" class="btn btn-orange text-white mt-2 px-4 shadow-sm">Book a New Flight Now</a>
                </div>
            }
            else
            {
                @foreach (var booking in Model.ActiveBooking)
                {
                    <div class="card shadow-sm mb-4 border-start border-orange border-4">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-md-3">
                                    <span class="text-uppercase small text-muted d-block">PNR Reference</span>
                                    <strong class="text-orange font-monospace fs-4">@booking.PNR</strong>
                                    <span class="d-block small text-secondary mt-1">Booked: @booking.BookingDate.ToString("dd MMM yyyy")</span>
                                </div>
                                <div class="col-md-5 border-start border-end px-4">
                                    <h5 class="mb-1 text-navy fw-bold">
                                        @booking.Flight.FromAirport.City (@booking.Flight.FromAirport.IATACode)
                                        <i class="bi bi-arrow-right text-orange mx-2"></i>
                                        @booking.Flight.ToAirport.City (@booking.Flight.ToAirport.IATACode)
                                    </h5>
                                    <span class="small d-block text-dark fw-semibold">
                                        <i class="bi bi-airplane-fill me-1 text-secondary"></i> @booking.Flight.Airline.AirlineName (@booking.Flight.FlightNumber)
                                    </span>
                                    <span class="small d-block text-muted">
                                        <i class="bi bi-clock me-1"></i> Departs: @booking.Flight.DepartureTime.ToString("dd MMM yyyy HH:mm")
                                    </span>
                                </div>
                                <div class="col-md-2 text-center">
                                    <span class="text-uppercase small text-muted d-block">Total Passengers</span>
                                    <span class="fs-5 fw-bold text-navy">@booking.Passengers.Count</span>
                                    <span class="d-block small fw-bold text-success mt-1">INR @booking.TotalAmount.ToString("N2")</span>
                                </div>
                                <div class="col-md-2 text-end">
                                    <a asp-action="DownloadTicket" asp-controller="Booking" asp-route-pnr="@booking.PNR" class="btn btn-outline-navy w-100 btn-sm mb-2">
                                        <i class="bi bi-file-earmark-pdf-fill text-danger me-1"></i> E-Ticket PDF
                                    </a>
                                    @if (booking.Status != "Cancelled")
                                    {
                                        <form asp-action="CancelBooking" asp-controller="Booking" method="post" onsubmit="return confirm('Are you sure you want to cancel this booking? A fee of INR 1,500 per passenger will be deducted.');">
                                            <input type="hidden" name="pnr" value="@booking.PNR" />
                                            <button type="submit" class="btn btn-outline-danger w-100 btn-sm">
                                                <i class="bi bi-x-circle me-1"></i> Cancel Booking
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger w-100 py-2">Cancelled</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="tab-pane fade" id="past" role="tabpanel">
            @if (!Model.PastBooking.Any())
            {
                <div class="text-center p-5 border rounded bg-light">
                    <i class="bi bi-archive text-muted display-4"></i>
                    <h5 class="mt-3 text-secondary">No historical travel files located.</h5>
                </div>
            }
            else
            {
                <div class="table-responsive border rounded bg-white p-3 shadow-sm">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>PNR</th>
                                <th>Route Path</th>
                                <th>Date of Travel</th>
                                <th>Manifest Size</th>
                                <th>Fare Settled</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var booking in Model.PastBooking)
                            {
                                <tr>
                                    <td><strong class="font-monospace text-secondary">@booking.PNR</strong></td>
                                    <td>
                                        <span class="fw-semibold">@booking.Flight.FromAirport.IATACode &rarr; @booking.Flight.ToAirport.IATACode</span>
                                        <small class="d-block text-muted text-truncate" style="max-width: 180px;">@booking.Flight.Airline.AirlineName</small>
                                    </td>
                                    <td><small>@booking.Flight.DepartureTime.ToString("dd MMM yyyy")</small></td>
                                    <td>@booking.Passengers.Count Pax</td>
                                    <td><span class="small text-muted">INR @booking.TotalAmount.ToString("N2")</span></td>
                                    <td class="text-end">
                                        <a asp-action="DownloadTicket" asp-controller="Booking" asp-route-pnr="@booking.PNR" class="btn btn-light btn-sm border">
                                            <i class="bi bi-download me-1 text-primary"></i> Invoice
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>