@* Views/Booking/CancellationSuccess.cshtml *@
@model FlightBooking.Web.Models.ViewModels.CancellationResultViewModel
@{
    ViewData["Title"] = "Cancellation Processed";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0 p-4">
                <div class="card-body text-center">
                    <i class="bi bi-x-circle-fill text-danger display-3"></i>
                    <h2 class="text-navy fw-bold mt-3">Cancellation Settled</h2>
                    <p class="text-muted">Your booking reference PNR <strong class="font-monospace text-dark">@Model.PNR</strong> has been officially updated to cancelled status.</p>

                    <div class="bg-light p-3 rounded my-4 border text-start">
                        <h6 class="fw-bold border-bottom pb-2 text-navy mb-3">Financial Settlement Breakdown</h6>
                        <div class="d-flex justify-content-between my-1">
                            <span class="text-secondary">Original Amount Paid:</span>
                            <span>INR @Model.OriginalAmount.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between my-1 text-danger">
                            <span>Cancellation Penalty Fees (Pax count-based):</span>
                            <span>- INR @Model.CancellationPenalty.ToString("N2")</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between my-1 fw-bold text-success fs-5">
                            <span>Refund Credit Due:</span>
                            <span>INR @Model.RefundAmount.ToString("N2")</span>
                        </div>
                    </div>

                    <div class="alert alert-dark small text-start border-0 bg-navy text-white font-monospace p-3">
                        <i class="bi bi-terminal me-2 text-warning"></i>@Model.WebhookSimulationStatus
                        <br /><span class="text-muted mt-2 d-block">Gateway Terminal ID Reference: @Model.RefundReferenceId</span>
                    </div>

                    <a asp-action="MyBookings" asp-controller="Booking" class="btn btn-outline-navy px-4 mt-3">Return to Travel Dashboard</a>
                </div>
            </div>
        </div>
    </div>
</div>