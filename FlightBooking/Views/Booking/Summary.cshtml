@model FlightBooking.Web.Models.ViewModels.BookingSummary
@{
    ViewData["Title"] = "Review Your Booking";
}

<div class="container my-5">
    <div class="row mb-4">
        <div class="col-12 text-center">
            <div class="d-flex justify-content-center align-items-center gap-3">
                <span class="badge bg-secondary p-2">1. Select Flight</span>
                <span class="text-muted">&rarr;</span>
                <span class="badge bg-secondary p-2">2. Choose Seats</span>
                <span class="text-muted">&rarr;</span>
                <span class="badge bg-secondary p-2">3. Passengers</span>
                <span class="text-muted">&rarr;</span>
                <span class="badge bg-navy p-2 text-white text-uppercase">4. Review & Add-ons</span>
                <span class="text-muted">&rarr;</span>
                <span class="badge bg-light text-muted p-2">5. Payment</span>
            </div>
        </div>
    </div>

    <form asp-controller="Booking" asp-action="ConfirmAddOns" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="FlightId" />
        <input type="hidden" asp-for="PassengerCount" />
        <input type="hidden" asp-for="BaseFareAndSeatsTotal" />

        <div class="row">
            <div class="col-md-8">
                <div class="card p-4 shadow-sm border-0 mb-4 bg-light">
                    <h4 class="text-navy fw-bold mb-3">Review Flight Itinerary</h4>
                    <div class="row text-center text-md-start">
                        <div class="col-md-4">
                            <h5>@Model.Flight.DepartureTime.ToString("HH:mm")</h5>
                            <p class="text-muted m-0">@Model.Flight.FromAirport.City (@Model.Flight.FromAirport.IATACode)</p>
                            <small class="text-muted">@Model.Flight.DepartureTime.ToString("dd MMM yyyy")</small>
                        </div>
                        <div class="col-md-4 text-center py-2">
                            <span class="badge bg-secondary text-uppercase py-2">@Model.Flight.FlightNumber</span>
                            <hr class="my-2" />
                            <small class="text-muted d-block">Non-Stop Service</small>
                        </div>
                        <div class="col-md-4 text-md-end">
                            <h5>@Model.Flight.ArrivalTime.ToString("HH:mm")</h5>
                            <p class="text-muted m-0">@Model.Flight.ToAirport.City (@Model.Flight.ToAirport.IATACode)</p>
                            <small class="text-muted">@Model.Flight.ArrivalTime.ToString("dd MMM yyyy")</small>
                        </div>
                    </div>
                </div>

                <h4 class="text-navy fw-bold mb-3">Customize Comfort & Add-ons</h4>
                @for (int i = 0; i < Model.Passengers.Count; i++)
                {
                    <input type="hidden" asp-for="Selections[i].PassengerIndex" value="@i" />
                    
                    <div class="card p-4 shadow-sm border-0 mb-4">
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                            <h5 class="text-navy fw-bold m-0">@Model.Passengers[i].Name</h5>
                            <span class="badge bg-navy text-white px-3 py-2">Seat @Model.Passengers[i].SeatNumber</span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">Excess Baggage Allowance</label>
                                <select asp-for="Selections[i].SelectedBaggageId" class="form-select baggage-select" data-pax-index="@i">
                                    @foreach (var bag in Model.AvailableBaggage)
                                    {
                                        <option value="@bag.Id" data-price="@bag.Price">@bag.Label + (INR @bag.Price)</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">In-Flight Dining Choice</label>
                                <select asp-for="Selections[i].SelectedMealId" class="form-select meal-select" data-pax-index="@i">
                                    @foreach (var meal in Model.AvailableMeals)
                                    {
                                        <option value="@meal.Id" data-price="@meal.Price">@meal.Name + (INR @meal.Price)</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="col-md-4">
                <div class="card p-4 shadow-sm border-0 position-sticky bg-navy text-white" style="top: 20px; background-color: #1a1a2e;">
                    <h4 class="pb-2 border-bottom border-secondary text-white">Payment Summary</h4>
                    
                    <div class="d-flex justify-content-between align-items-center my-3">
                        <span class="text-muted small">Base Fare & Seats:</span>
                        <span class="fw-bold text-white">INR @string.Format("{0:N2}", Model.BaseFareAndSeatsTotal)</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center my-3">
                        <span class="text-muted small">Ancillary Services:</span>
                        <span class="fw-bold text-white" id="ancillary-total-display">INR 0.00</span>
                    </div>
                    
                    <hr class="border-secondary" />

                    <div class="d-flex justify-content-between align-items-center my-4">
                        <h5 class="m-0 text-white">Grand Total:</h5>
                        <h3 class="fw-bold m-0" style="color: #ff6f3c;" id="grand-total-display">INR @string.Format("{0:N2}", Model.BaseFareAndSeatsTotal)</h3>
                    </div>

                    <button type="submit" class="btn btn-warning w-100 fw-bold py-3 text-uppercase border-0 shadow-sm" style="background-color: #ff6f3c !important; color: #ffffff;">
                        Proceed to Payment
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const baseFareAndSeats = parseFloat("@Model.BaseFareAndSeatsTotal".replace(/,/g, '')) || 0.0;

            function recalculateTotals() {
                let ancillaryTotal = 0.0;

                // Loop through selected baggage items and extract prices via data descriptors
                document.querySelectorAll(".baggage-select").forEach(function (select) {
                    const selectedOpt = select.options[select.selectedIndex];
                    if (selectedOpt) {
                        ancillaryTotal += parseFloat(selectedOpt.getAttribute("data-price")) || 0.0;
                    }
                });

                // Loop through selected dining items
                document.querySelectorAll(".meal-select").forEach(function (select) {
                    const selectedOpt = select.options[select.selectedIndex];
                    if (selectedOpt) {
                        ancillaryTotal += parseFloat(selectedOpt.getAttribute("data-price")) || 0.0;
                    }
                });

                const grandTotal = baseFareAndSeats + ancillaryTotal;

                // Update text configurations dynamically
                const ancillaryTotalDisplay = document.getElementById("ancillary-total-display");
                const grandTotalDisplay = document.getElementById("grand-total-display");

                if (ancillaryTotalDisplay) {
                    ancillaryTotalDisplay.innerText = "INR " + ancillaryTotal.toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,');
                }
                if (grandTotalDisplay) {
                    grandTotalDisplay.innerText = "INR " + grandTotal.toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,');
                }
            }

            // Listen for tracking changes on inputs
            document.addEventListener("change", function (e) {
                if (e.target && (e.target.classList.contains("baggage-select") || e.target.classList.contains("meal-select"))) {
                    recalculateTotals();
                }
            });

            // Run initial execution count on window ready
            recalculateTotals();
        });
    </script>
}
<style>
    .text-navy { color: #1a1a2e; }
    .bg-navy { background-color: #1a1a2e !important; }
</style>