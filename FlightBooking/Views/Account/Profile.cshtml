
@model FlightBooking.Web.Models.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-4">
    <h4 class="mb-4">
        <i class="bi bi-person-circle me-2"></i>My profile
    </h4>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible">
            @TempData["Success"]
            <button type="button" class="btn-close"
                    data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        <!-- Left — avatar + photo upload -->
        <div class="col-md-3 text-center">
            <div class="card border-0 shadow-sm p-3">
                @if (!string.IsNullOrEmpty(Model.CurrentPhotoUrl))
                {
                    <img src="@Model.CurrentPhotoUrl"
                         class="rounded-circle mb-3"
                         width="100" height="100"
                         style="object-fit:cover"
                         alt="Profile photo" />
                }
                else
                {
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3"
                         style="width:100px;height:100px;font-size:2rem">
                        @Model.FullName?.Substring(0, 1).ToUpper()
                    </div>
                }
                <p class="fw-500 mb-0">@Model.FullName</p>
                <p class="text-muted small">@Model.Email</p>
                <a asp-action="ChangePassword"
                   class="btn btn-sm btn-outline-secondary mt-2">
                    <i class="bi bi-key me-1"></i>Change password
                </a>
            </div>
        </div>

        <!-- Right — edit form -->
        <div class="col-md-9">
            <div class="card border-0 shadow-sm p-4">
                <h6 class="fw-500 mb-3">Edit details</h6>

                <form asp-action="Profile" method="post"
                      enctype="multipart/form-data">

                    <div asp-validation-summary="All"
                         class="alert alert-danger py-2 small"
                         style="display:none"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName"
                                   class="form-label"></label>
                            <input asp-for="FullName"
                                   class="form-control" />
                            <span asp-validation-for="FullName"
                                  class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber"
                                   class="form-label"></label>
                            <input asp-for="PhoneNumber"
                                   class="form-control" />
                            <span asp-validation-for="PhoneNumber"
                                  class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input value="@Model.Email"
                                   class="form-control"
                                   disabled />
                            <div class="form-text">
                                Email cannot be changed here.
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProfilePhoto"
                                   class="form-label"></label>
                            <input asp-for="ProfilePhoto"
                                   type="file"
                                   accept=".jpg,.jpeg,.png"
                                   class="form-control" />
                            <div class="form-text">
                                JPG or PNG, max 2 MB.
                            </div>
                            <span asp-validation-for="ProfilePhoto"
                                  class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit"
                                class="btn btn-primary px-4"
                                style="background:#003580;border:none">
                            <i class="bi bi-check-lg me-1"></i>
                            Save changes
                        </button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync(
                "_ValidationScriptsPartial");
    }
    <script>
        const vs = document.querySelector(
          '[data-valmsg-summary]');
        if (vs && vs.querySelectorAll('li').length)
          vs.style.display = 'block';
    </script>
}