@model List<FlightBooking.Models.ViewModels.FlightSearchResultViewModel>
@{
    ViewData["Title"] = "Search results";
    var sm = ViewBag.SearchModel as FlightBooking.Models.ViewModels.SearchViewModel;
}

<div class="container py-4">

    <!-- header row -->
    <div class="d-flex align-items-center
              justify-content-between mb-3">
        <div>
            <h5 class="mb-0">
                @ViewBag.FromAirportName
                <i class="bi bi-arrow-right mx-2"></i>
                @ViewBag.ToAirportName
            </h5>
            <p class="text-muted small mb-0">
                @sm?.DepartureDate.ToString("ddd, dd MMM yyyy")
                ·  @sm?.Passengers passenger(s)
                ·  @sm?.JourneyClass
                ·
                <strong>@ViewBag.ResultCount flight(s) found</strong>
            </p>
        </div>
        <a asp-controller="Home" asp-action="Index"
           class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Modify search
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-airplane text-muted"
               style="font-size:3rem"></i>
            <h5 class="mt-3">No flights found</h5>
            <p class="text-muted">
                Try a different date or route.
            </p>
        </div>
    }
    else
    {
    <div class="d-flex flex-column gap-3">
        @foreach (var f in Model)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="row align-items-center">

                        <!-- airline -->
                        <div class="col-md-2 text-center">
                            @if (!string.IsNullOrEmpty(f.AirlineLogoUrl))
                            {
                                <img src="@f.AirlineLogoUrl"
                                     height="32" alt="@f.AirlineName"
                                     onerror="this.style.display='none'" />
                            }
                            <p class="small mb-0 text-muted">
                                @f.AirlineName
                            </p>
                            <p class="small mb-0 text-muted">
                                @f.FlightNumber
                            </p>
                        </div>

                        <!-- departure -->
                        <div class="col-md-2 text-center">
                            <p class="fs-5 fw-500 mb-0">
                                @f.DepartureTime.ToString("HH:mm")
                            </p>
                            <p class="small text-muted mb-0">
                                @f.FromIATA — @f.FromCity
                            </p>
                        </div>

                        <!-- duration -->
                        <div class="col-md-2 text-center">
                            <p class="small text-muted mb-1">
                                @f.DurationDisplay
                            </p>
                            <div style="position:relative;
                                height:2px;
                                background:#e5e7eb;
                                border-radius:2px">
                                <i class="bi bi-airplane-fill"
                                   style="position:absolute;
                                 right:-4px;top:-7px;
                                 font-size:14px;
                                 color:#003580"></i>
                            </div>
                            <p class="small text-muted mt-1 mb-0">
                                Non-stop
                            </p>
                        </div>

                        <!-- arrival -->
                        <div class="col-md-2 text-center">
                            <p class="fs-5 fw-500 mb-0">
                                @f.ArrivalTime.ToString("HH:mm")
                            </p>
                            <p class="small text-muted mb-0">
                                @f.ToIATA — @f.ToCity
                            </p>
                        </div>

                        <!-- seats -->
                        <div class="col-md-2 text-center">
                            <p class="small mb-0">
                                @f.AvailableSeats seats left
                            </p>
                            <p class="small text-muted mb-0">
                                @f.AircraftType
                            </p>
                        </div>

                        <!-- price + book -->
                        <div class="col-md-2 text-center">
                            <p class="fs-5 fw-500 mb-0"
                               style="color:#003580">
                                ₹@f.TotalPrice.ToString("N0")
                            </p>
                            <p class="small text-muted mb-2">
                                ₹@f.BasePrice.ToString("N0") / person
                            </p>
                            @if (f.HasSeats)
                            {
                                    <a asp-controller="Flight"
                                       asp-action="SeatMap"
                                       asp-route-flightId="@f.FlightId"
                                       asp-route-passengers="@sm?.Passengers"
                                       asp-route-journeyClass="@sm?.JourneyClass"
                                       class="btn btn-warning fw-bold px-4 text-white text-uppercase">
                                        Book Now
                                    </a>
                            }
                            else
                            {
                            <button class="btn btn-sm
                                      btn-outline-secondary
                                      w-100"
                                    disabled>
                                Sold out
                            </button>
                            }
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
    }
</div>